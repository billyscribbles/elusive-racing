# Elusive Racing — environment variable reference
#
# Copy this file to `.env` and fill in real values for local development. On
# Railway, set the same keys in the project's Variables tab. Production refuses
# to start (server.js validateProductionConfig) if any required server var is
# missing or still set to a placeholder — see the boot log for specifics.
#
# Naming convention:
#   VITE_*            — exposed to the browser bundle by Vite (publishable only)
#   everything else   — server-only, never inlined into the client bundle
#
# Never commit a filled-in `.env`. `.gitignore` excludes it; `scripts/scan-secrets.mjs`
# also runs as a postbuild step and fails the build if any live secret leaks into dist/.

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development          # 'production' on Railway
PORT=8080

# ── WooCommerce (server-only) ────────────────────────────────────────────────
# WC consumer key/secret are server-only. The frontend reaches WC REST via the
# /api/wc/* proxy in server.js, which adds Basic auth using these values.
# The legacy VITE_WC_CONSUMER_* names are deprecated and will fail prod boot.
WC_URL=https://elusiveracing.com.au
WC_CONSUMER_KEY=YOUR_WC_CONSUMER_KEY_HERE
WC_CONSUMER_SECRET=YOUR_WC_CONSUMER_SECRET_HERE

# WC URL is also read by the React client (a public URL — safe to ship). Keep
# the VITE_ copy in sync with WC_URL.
VITE_WC_URL=https://elusiveracing.com.au

# ── Stripe ───────────────────────────────────────────────────────────────────
# Server uses the secret key (format: sk_test_… in dev, sk_live_… in prod).
# Browser uses the publishable key (pk_test_… / pk_live_…) only.
# Production rejects test keys at boot — see validateProductionConfig in server.js.
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
VITE_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE

# ── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_ENV=sandbox            # 'live' on Railway
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_SECRET=YOUR_PAYPAL_SECRET_HERE
# PayPal client ID is also needed by the frontend SDK script.
VITE_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# ── Afterpay (warn-only until keys are issued) ───────────────────────────────
AFTERPAY_ENV=sandbox          # 'live' on Railway once keys are in place
AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET=
VITE_AFTERPAY_ENABLED=0       # '1' to show the Afterpay option at checkout

# ── Admin auth ───────────────────────────────────────────────────────────────
# ADMIN_JWT_SECRET signs the admin session JWT. Use a long random string;
# production refuses to start if it equals 'change-me-in-production' or is unset.
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Production refuses to start with an
# empty allowlist (would otherwise fall back to wildcard '*').
ALLOWED_ORIGINS=http://localhost:5173,https://elusive-racing-production-d535.up.railway.app

# ── Meilisearch ──────────────────────────────────────────────────────────────
# Admin key is server-only (used by /api/sync). The search-only key is exposed
# to the browser for client-side search.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=masterKey
VITE_MEILISEARCH_HOST=http://localhost:7700
VITE_MEILISEARCH_SEARCH_KEY=masterKey
SEARCH_SYNC_TOKEN=

# ── Anthropic (chat widget) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Sentry ───────────────────────────────────────────────────────────────────
# Empty DSN disables Sentry (the SDK becomes a no-op). Server uses SENTRY_DSN
# directly; the React client reads VITE_SENTRY_DSN.
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_RELEASE=               # Optional — defaults to RAILWAY_GIT_COMMIT_SHA on Railway

# ── Frontend metadata ────────────────────────────────────────────────────────
VITE_APP_VERSION=             # Optional — surfaced in the chat widget footer
