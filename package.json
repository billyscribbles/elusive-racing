{
  "name": "elusive-racing",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n meili,server,vite -c magenta,cyan,green \"./bin/meilisearch --master-key=masterKey --no-analytics\" \"node server.js\" \"vite\"",
    "dev:all": "concurrently -n server,vite,search -c cyan,green,magenta \"node server.js\" \"vite\" \"node search-server/server.js\"",
    "build": "vite build && node scripts/build-sitemap.mjs && node scripts/scan-secrets.mjs",
    "preview": "vite preview",
    "start": "node server.js",
    "server": "lsof -ti :8080 | xargs kill -9 2>/dev/null; yarn node server.js",
    "search-server": "node search-server/server.js",
    "search-sync": "node --env-file=.env -e \"import('./search-server/sync.js').then(m => m.runFullSync().then(() => process.exit(0)))\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@paypal/react-paypal-js": "^9.1.1",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tinymce/tinymce-react": "^6.3.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.5",
    "meilisearch": "^0.57.0",
    "react": "^18.3.1",
    "react-cookie-consent": "^10.0.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^6.28.0",
    "react-svg-credit-card-payment-icons": "^5.1.2",
    "stripe": "^21.0.1",
    "tinymce": "^8.4.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "serve": "^14.2.4",
    "typescript": "^5.9.3",
    "vite": "^6.0.5",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-static-copy": "^4.1.0"
  },
  "packageManager": "yarn@4.12.0+sha512.f45ab632439a67f8bc759bf32ead036a1f413287b9042726b7cc4818b7b49e14e9423ba49b18f9e06ea4941c1ad062385b1d8760a8d5091a1a31e5f6219afca8"
}
