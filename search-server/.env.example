# ── WooCommerce (copy from root .env) ─────────────────────────────────────────
# These are already in the root .env and will be picked up automatically
# when running locally. Only set these if deploying the server standalone.
VITE_WC_URL=https://elusiveracing.com.au
VITE_WC_CONSUMER_KEY=ck_...
VITE_WC_CONSUMER_SECRET=cs_...

# ── Meilisearch ────────────────────────────────────────────────────────────────
# Admin key — used by this server to write/index documents. Keep this SECRET.
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=masterKey

# ── Search server ──────────────────────────────────────────────────────────────
SEARCH_SERVER_PORT=3001

# Optional: Bearer token to protect the POST /sync endpoint.
# Leave blank in dev (no auth). Set to a strong secret in production.
SEARCH_SYNC_TOKEN=

# Cron schedule for automatic re-sync (default: every hour at :00)
# Format: minute hour day month weekday
SEARCH_SYNC_CRON=0 * * * *
